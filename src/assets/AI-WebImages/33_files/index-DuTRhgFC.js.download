le:"Stations Management",description:"Complete station database with capacity and inventory tracking",image:Ca},{title:"Trip Management",description:"Track and approve all deliveries with real-time updates",image:_d},{title:"Live GPS Tracking",description:"Monitor fleet location and delivery progress in real-time",image:Ps},{title:"Driver Management",description:"Manage driver schedules, hours, and compliance",image:lb},{title:"Fleet Overview",description:"Track trucks, capacity, and maintenance schedules",image:ub},{title:"Depot Management",description:"Manage depot inventory and distribution centers",image:Yp}],i=()=>{e(T=>(T+1)%n.length)};M.useEffect(()=>{const T=setInterval(i,4e3);return()=>clearInterval(T)},[]);const o=[{id:"stations",label:"Active Stations",target:500,suffix:"+"},{id:"deliveries",label:"Deliveries/Month",target:1e4,displayAs:"k",suffix:"+"},{id:"uptime",label:"Uptime",target:99.9,decimals:1,suffix:"%"},{id:"support",label:"Support",target:24,suffix:"/7"}],a=M.useRef(null),[u,d]=M.useState(o.map(()=>0)),[h,p]=M.useState(!1);M.useEffect(()=>{if(!a.current)return;const T=new IntersectionObserver(R=>{R.forEach(B=>{B.isIntersecting&&!h&&(p(!0),o.forEach((S,I)=>{const G=S.target,ie=1200+I*250,ee=performance.now(),Se=me=>{const le=me-ee,pe=Math.min(le/ie,1),te=1-Math.pow(1-pe,3),W=0+(G-0)*te;d(J=>{const E=[...J];return E[I]=W,E}),pe<1&&requestAnimationFrame(Se)};requestAnimationFrame(Se)}))})},{threshold:.4});return T.observe(a.current),()=>T.disconnect()},[h]);const[g,y]=M.useState(0),[v,w]=M.useState(null),[j,b]=M.useState(!1),N=["Dynamic Orders","Optimized Trips","Intelligent Resource Assignment","Real-Time Sequential Dispatch","Auto Stock Reconciliation"],[C,k]=M.useState(!1),D=[{title:"Dynamic Orders",description:"In the Dynamic Orders stage, the system intelligently receives, analyzes, and prioritizes all incoming orders, including both regular deliveries and urgent requests. It collects orders from multiple sources and evaluates key factors such as priority level, delivery time windows, location, package type, and urgency. Using historical data and real-time operational load, the AI engine decides which orders should be processed first and which can be grouped together for better efficiency. The main objective of this stage is to balance the order flow, reduce bottlenecks, and ensure that every order enters the planning pipeline at the right time with the right priority.",video:E3,poster:Ca},{title:"Optimized Trips",description:"In the Optimized Trips stage, the system designs the most efficient delivery routes and trip plans to minimize time, fuel consumption, and operational costs. It takes into account live traffic conditions, road constraints, distances, risk factors, and delivery deadlines. The AI engine creates multi-stop trips that allow multiple deliveries to be completed in a single run, improving overall efficiency. If real-world conditions change, such as traffic congestion or route disruptions, the system automatically re-optimizes the routes to keep deliveries fast, safe, and reliable.",video:Zc,poster:_d},{title:"Intelligent Resource Assignment",description:"During the Intelligent Resource Assignment stage, the system matches each trip with the most suitable driver and vehicle. It analyzes driver availability, skills, experience, and current location, along with vehicle capacity, condition, and compliance requirements. By using an AI-based compatibility and scoring mechanism, the system ensures that the right driver and the right vehicle are assigned to the right job. This reduces errors such as overloading or poor assignments, improves safety, and increases overall operational efficiency.",video:P3,poster:Yp},{title:"Real-Time Sequential Dispatch",description:"In the Real-Time Sequential Dispatch stage, the entire delivery operation is monitored and managed in real time. The system tracks vehicles and orders using live GPS and status updates, continuously monitoring progress, delays, and e